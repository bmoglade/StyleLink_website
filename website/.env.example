# ===========================================
# StyleLink Environment Variables
# ===========================================
# Copy this file to .env.local for development
# Copy this file to .env.production for production
# ===========================================

# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Analytics (GA4)
# Get this from: https://analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Application URL
# Development: http://localhost:3000
# Production: https://yourdomain.com (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment
# Values: development | production
NODE_ENV=development
